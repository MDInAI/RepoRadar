# Backend Environment Example
# Copy to .env and customize as needed.

# Application
ENVIRONMENT=local
LOG_LEVEL=INFO
API_V1_STR=/api/v1
FRONTEND_PORT=3000

# Project-owned runtime
DATABASE_URL=sqlite:///../runtime/data/sqlite/agentic_workflow.db
AGENTIC_RUNTIME_DIR=../runtime
OPENCLAW_WORKSPACE_DIR=/absolute/path/to/your/openclaw/workspace

# OpenClaw-owned config reference
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# Project-owned provider credentials and pacing
GITHUB_PROVIDER_TOKEN=
GITHUB_REQUESTS_PER_MINUTE=60
INTAKE_PACING_SECONDS=30

# Optional future app secret; do not commit real values
SECRET_KEY=
