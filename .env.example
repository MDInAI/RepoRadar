# Agentic-Workflow Root Environment Example
# Copy to .env and customize as needed.
# OpenClaw-native secrets stay in ~/.openclaw/openclaw.json or local shell env.

# Service ports
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Project runtime
# These paths are exported into backend/ and workers/ subprocesses by scripts/dev.sh.
DATABASE_URL=sqlite:///../runtime/data/sqlite/agentic_workflow.db
AGENTIC_RUNTIME_DIR=../runtime
OPENCLAW_WORKSPACE_DIR=/absolute/path/to/your/openclaw/workspace
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# Project-owned provider pacing
GITHUB_PROVIDER_TOKEN=
# Set GITHUB_PROVIDER_TOKEN for live intake against the GitHub provider.
GITHUB_REQUESTS_PER_MINUTE=60
INTAKE_PACING_SECONDS=30

# Worker Firehose/Backfill/Bouncer Pacing
FIREHOSE_INTERVAL_SECONDS=3600
FIREHOSE_PER_PAGE=100
FIREHOSE_PAGES=3
BACKFILL_INTERVAL_SECONDS=21600
BACKFILL_PER_PAGE=100
BACKFILL_PAGES=2
BACKFILL_WINDOW_DAYS=30
BACKFILL_MIN_CREATED_DATE=2008-01-01
BOUNCER_INCLUDE_RULES=saas,developer tools,infrastructure
BOUNCER_EXCLUDE_RULES=gaming,homework,tutorial

# Logging
LOG_LEVEL=INFO
