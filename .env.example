# Agentic-Workflow Root Environment Example
# Copy to .env and customize as needed.
# OpenClaw-native secrets stay in ~/.openclaw/openclaw.json or local shell env.

# Service ports
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Project runtime
# These paths are exported into backend/ and workers/ subprocesses by scripts/dev.sh.
DATABASE_URL=sqlite:///../runtime/data/sqlite/agentic_workflow.db
AGENTIC_RUNTIME_DIR=../runtime
OPENCLAW_WORKSPACE_DIR=/absolute/path/to/your/openclaw/workspace
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# Project-owned provider pacing
GITHUB_REQUESTS_PER_MINUTE=60
INTAKE_PACING_SECONDS=30

# Logging
LOG_LEVEL=INFO
